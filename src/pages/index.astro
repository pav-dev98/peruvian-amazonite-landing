---
import "../styles/global.css";
// Component Imports
import AboutMine from "../components/AboutMine";
import ContactForm from "../components/ContactForm";
import HeroSection from "../components/HeroSection";
import Header from "../components/Header";
import TrustBar from "../components/TrustBar";
import ProductGrading from "../components/ProductGrading";
import Footer from "@/components/Footer";
import WhatsAppButton from "@/components/WhatsAppButton";
import WhyPartner from "@/components/WhyPartner";
import { Toaster } from "@/components/ui/sonner";
import { ThemeProvider } from "@/components/ThemeProvider";

// Full Astro Component Syntax:
// https://docs.astro.build/basics/astro-components/
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/logo-f.svg" />
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href="/favicon-32.png"
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="48x48"
			href="/favicon-48.png"
		/>
		<link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
		<link
			rel="icon"
			type="image/png"
			sizes="192x192"
			href="/favicon-192.png"
		/>
		<meta name="generator" content={Astro.generator} />
		<title>
			Wholesale Amazonite Supplier - Direct Peruvian Source Export
		</title>
		<meta
			name="description"
			content="Source high-quality Peruvian Amazonite in bulk. Direct access to certified mines in the Amazonas region. Ethical sourcing, expert grading, and global logistics. Request a wholesale quote."
		/>
		<meta
			name="keywords"
			content="amazonite wholesale, peruvian amazonite supplier, bulk amazonite, amazonite rough stones, amazonite exporter, amazonite wholesale supplier"
		/>
		<meta
			property="og:title"
			content="Premium Peruvian Amazonite - Direct Source to Global Markets"
		/>
		<meta
			property="og:description"
			content="Exclusive access to premium Peruvian Amazonite from certified mines in the Amazonas region. Ethically sourced, expertly graded, and shipped worldwide."
		/>
		<meta property="og:type" content="website" />
		<meta
			property="og:url"
			content="https://wholesale.blueamazoniteperu.com"
		/>
		<meta
			property="og:image"
			content="https://wholesale.blueamazoniteperu.com/og-image-light.png"
		/>
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta name="twitter:card" content="summary_large_image" />
		<meta
			name="twitter:image"
			content="https://wholesale.blueamazoniteperu.com/og-image-light.png"
		/>
		<link rel="canonical" href="https://wholesale.blueamazoniteperu.com" />
		<meta
			name="google-site-verification"
			content="-d_MSlyEPuIIvYAZ4s8_1LaIjCtF_gWgG1TiIhkp5qw"
		/>
		<script type="application/ld+json">
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "Organization",
						"name": "Blue Amazonite Peru",
						"url": "https://wholesale.blueamazoniteperu.com",
						"logo": "https://wholesale.blueamazoniteperu.com/logo-f.svg",
						"foundingDate": "2015",
						"description": "Peruvian amazonite wholesale supplier with exclusive access to certified mines in the Amazonas region. Bulk rough and semi-polished stones exported worldwide.",
						"address": {
							"@type": "PostalAddress",
							"addressCountry": "CL",
							"addressLocality": "Santiago",
							"streetAddress": "Santiago, Chile"
						},
						"contactPoint": {
							"@type": "ContactPoint",
							"telephone": "+56928260797",
							"contactType": "sales",
							"availableLanguage": ["English", "Spanish"]
						},
						"sameAs": []
					},
					{
						"@type": "Service",
						"name": "Peruvian Amazonite Wholesale Export",
						"description": "Premium bulk amazonite rough stones sourced directly from certified mines in the Amazonas region of Peru. Available in Grade AAA, AA, and A.",
						"provider": {
							"@type": "Organization",
							"name": "Blue Amazonite Peru"
						},
						"areaServed": {
							"@type": "Place",
							"name": "Worldwide"
						},
						"serviceType": "Wholesale Mineral Export",
						"keywords": "peruvian amazonite wholesale, bulk amazonite rough stones, amazonite exporter peru"
					}
				]
			}
		</script>
	</head>

	<body>
		<!-- <ThemeProvider></ThemeProvider> engloba todo el contenido -->
		<Toaster client:load />
		<div class="min-h-screen">
			<Header client:load />
			<main>
				<HeroSection client:load />
				<TrustBar />
				<ProductGrading />
				<WhyPartner />
				<AboutMine />
				<ContactForm client:load />
			</main>
			<Footer />
			<WhatsAppButton />
		</div>
	</body>
</html>
